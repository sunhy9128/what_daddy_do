{
  "expo": {
    "name": "爸爸去哪了",
    "slug": "what-dad-do-vibe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "what-dad-do-vibe",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF5F0"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "package": "com.seansun.whatdaddovibe",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF5F0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "react-native-svg"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e74018ba-6f34-4ecc-9f12-b2222f6ae95b"
      }
    },
    "owner": "sean_sun"
  }
}
